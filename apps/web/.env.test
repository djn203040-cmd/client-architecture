# Local Supabase keys. These demo anon/service-role JWTs are deterministic —
# `supabase start` produces the same ones on every machine (default JWT secret),
# so they can live here for local E2E runs. CI overrides via `supabase status`.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdp7fsn3W0YpN81IU

# App base URL — routes build absolute URLs from this (new URL("/login", APP_URL)).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stub external service creds — real APIs never called in tests
GOOGLE_CLIENT_ID=test-client-id
GOOGLE_CLIENT_SECRET=test-client-secret
RESEND_API_KEY=test-resend-key
SLACK_SIGNING_SECRET=test-slack-secret
TWILIO_AUTH_TOKEN=test-twilio-token
ANTHROPIC_API_KEY=test-anthropic-key
INNGEST_SIGNING_KEY=test-inngest-key
INNGEST_EVENT_KEY=test-inngest-event-key

# Transcript encryption key (test-only value)
TRANSCRIPT_ENCRYPTION_KEY=4282eC5g2ZdY5Nxwhsm1AwFyCuc1S88FoGYzrHZ0dZ4=

# Token-signing secrets — E2E specs sign tokens the routes must verify.
# Must match the fallbacks hard-coded in the specs (and the CI workflow env).
UNSUBSCRIBE_SECRET=test-unsub-secret
JWT_REVIEW_SECRET=test-review-secret

# No Inngest dev server in local/CI E2E — make event emission a no-op so
# event-emitting routes don't 401→500 against Inngest Cloud.
INNGEST_TEST_NOOP=1
