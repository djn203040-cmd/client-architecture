# Stub external service creds — real APIs never called in tests
GOOGLE_CLIENT_ID=test-client-id
GOOGLE_CLIENT_SECRET=test-client-secret
RESEND_API_KEY=test-resend-key
SLACK_SIGNING_SECRET=test-slack-secret
