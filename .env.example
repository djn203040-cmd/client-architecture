# ============================================================
# The Client Architecture — Environment Variables
# Copy this file to .env.local and fill in values.
# NEVER commit .env.local or any .env file with real values.
# CI gitleaks job blocks commits that include real secrets.
# ============================================================

# ----- Supabase -----
# Public (safe to expose to browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. NEVER add NEXT_PUBLIC_ prefix — CI grep check fails the build if violated.
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_SECRET_KEY=

# Supabase CLI access token (for `supabase db push`) — local dev / CI only
SUPABASE_ACCESS_TOKEN=

# MUST use Supavisor port 6543 (transaction mode) — never 5432 (INFRA-004)
DATABASE_URL=postgres://postgres:[password]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# ----- App -----
# App URL (used for OAuth redirects, invite links, unsubscribe links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cron route shared-secret (Vercel Cron Jobs → Inngest dispatch)
CRON_SECRET=

# ----- Google / Gmail OAuth -----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/gmail/callback
# Gmail Pub/Sub topic for inbox push notifications
GMAIL_PUBSUB_TOPIC_NAME=projects/your-gcp-project/topics/gmail-watch
# Audience claim required on the JWT Google attaches to each push (matches subscription config)
GMAIL_PUBSUB_PUSH_AUDIENCE=https://your-app.vercel.app/api/webhooks/gmail/push
# Service account used to authenticate Pub/Sub pushes (verified against JWT email claim)
GMAIL_PUBSUB_PUSH_SERVICE_ACCOUNT=gmail-pubsub@your-gcp-project.iam.gserviceaccount.com

# ----- Anthropic (server-only; NEVER add NEXT_PUBLIC_ prefix) -----
ANTHROPIC_API_KEY=

# ----- Upstash Redis (rate limiting + cache) -----
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Vercel KV aliases (some libs read these instead)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ----- Inngest (workflow engine) -----
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ----- Resend (transactional email) -----
RESEND_API_KEY=
RESEND_WEBHOOK_SECRET=

# ----- Twilio (WhatsApp + SMS) -----
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_WHATSAPP_DRAFT_READY_CONTENT_SID=
TWILIO_WHATSAPP_DRAFT_FOLLOWUP_CONTENT_SID=

# ----- Slack -----
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=
SLACK_OAUTH_STATE_SECRET=

# ----- Calendar provider webhook secrets -----
CALENDLY_WEBHOOK_SECRET=
CAL_COM_WEBHOOK_SECRET=
CALCOM_WEBHOOK_SECRET=
ACUITY_API_KEY=
SQUARE_WEBHOOK_SECRET=
# Setmore + MS Bookings + TidyCal — coach-supplied secrets stored in Vault per-coach.

# ----- Transcript providers -----
FIREFLIES_API_KEY=
FIREFLIES_WEBHOOK_SECRET=
ZOOM_WEBHOOK_SECRET_TOKEN=

# ----- Tokens / HMAC secrets -----
JWT_REVIEW_SECRET=
UNSUBSCRIBE_SECRET=
UNSUBSCRIBE_TOKEN_SECRET=

# ----- Instagram (Phase 2+; Meta app review prep) -----
INSTAGRAM_WEBHOOK_VERIFY_TOKEN=

# ----- Observability -----
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
