# ============================================================
# The Client Architecture — Environment Variables
# Copy this file to .env.local and fill in values.
# NEVER commit .env.local or any .env file with real values.
# ============================================================

# Supabase — public (safe to expose to browser)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# NEVER add NEXT_PUBLIC_ prefix to this key — server-side only.
# CI grep check (.github/workflows/ci.yml) will fail the build if violated.
SUPABASE_SERVICE_ROLE_KEY=

# Supabase CLI access token (for `supabase db push`)
SUPABASE_ACCESS_TOKEN=

# MUST use Supavisor port 6543 (transaction mode) — never 5432 (INFRA-004)
DATABASE_URL=

# App URL (used for OAuth redirects, invite links)
NEXT_PUBLIC_APP_URL=

# Google OAuth (Gmail API)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# Anthropic (ai-engine — server-side only, NEVER add NEXT_PUBLIC_ prefix)
ANTHROPIC_API_KEY=

# Upstash Redis (rate limiting)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Instagram Webhook verification token (for Meta app review)
INSTAGRAM_WEBHOOK_VERIFY_TOKEN=

# Inngest
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
